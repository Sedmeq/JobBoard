# ====================================================================
# .env nümunə şablonu — bunu .env adı ilə kopyalayıb real dəyərləri yazın.
# .NET konfiqurasiya açarları "__" (iki alt-xətt) ilə bölünür.
# ====================================================================

# ---- Database ----
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER\SQLEXPRESS;Database=JobBoardDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;Encrypt=False

# ---- JWT ----
JwtSettings__Secret=CHANGE_ME_minimum_32_characters_long
JwtSettings__Issuer=JobBoardAPI
JwtSettings__Audience=JobBoardClient
JwtSettings__AccessTokenExpiryMinutes=15
JwtSettings__RefreshTokenExpiryDays=7

# ---- Redis ----
Redis__ConnectionString=localhost:6379

# ---- Email (SMTP) ----
Email__FromEmail=your-email@example.com
Email__FromName=JobBoard
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUser=your-email@example.com
Email__SmtpPass=your-app-password

# ---- Storage ----
Storage__Type=Local
Storage__LocalPath=wwwroot/uploads
Storage__BaseUrl=https://localhost:7135

# ---- CORS ----
AllowedOrigins=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500

# ---- Google reCAPTCHA ----
ReCaptcha__SecretKey=your-recaptcha-secret-key

# ---- App URLs ----
App__FrontendBaseUrl=http://127.0.0.1:5500
App__ApiBaseUrl=https://localhost:7135

# ---- Serilog ----
Serilog__MinimumLevel=Information
